            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/c/Users/<USER>/.ai-tracker/aitracker.exe checkpoint claude --hook-input stdin"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\<USER>\\.pixel-agents\\hooks\\claude-hook.js\"",
