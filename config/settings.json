{
  "env": {
    "ADO_PAT": "<<YOUR_ADO_PAT_HERE>>",
    "ADO_MCP_AUTH_TOKEN": "<<YOUR_ADO_MCP_AUTH_TOKEN_HERE>>",
    "ADO_ORG": "tr-ggo",
    "ADO_PROJECT": "Mastersaf Fiscal Solutions",
    "TEAMS_WEBHOOK_URL_TAXREFORM_DEV_TECHOPS": "<<YOUR_TEAMS_WEBHOOK_URL_HERE>>",
    "TEAMS_WEBHOOK_URL_TAXONE_EVOLUCAO_TECNICA": "<<YOUR_TEAMS_WEBHOOK_URL_HERE>>"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\<USER>\\.pixel-agents\\hooks\\claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\<USER>\\.pixel-agents\\hooks\\claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\<USER>\\.pixel-agents\\hooks\\claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\<USER>\\.pixel-agents\\hooks\\claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
